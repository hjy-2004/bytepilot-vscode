{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/nicegui/static/tauri-v2-conf-schema.json",
  "productName": "BytePilot",
  "version": "0.7.1",
  "identifier": "com.bytepilot.app",
  "build": {
    "frontendDist": "../../../webview-ui/dist-desktop",
    "beforeDevCommand": "cd ../../webview-ui && npm run build:desktop",
    "beforeBuildCommand": "cd ../../webview-ui && npm run build:desktop"
  },
  "app": {
    "windows": [
      {
        "title": "BytePilot",
        "url": "index.desktop.html",
        "width": 900,
        "height": 700,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: http:; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://cdn.jsdelivr.net/gh/hjy-2004/bytepilot-vscode@master/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZERDgwNURCREY5QjkzQTMKUldTams1dmYyd1hZL2Zzc0xaQzVjM0Q3bGU1am05NjNzUTYvY2Z6ajFqbXVoVHVsVHNBZ3JRajIK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
