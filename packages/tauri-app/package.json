{
  "name": "@bytepilot/tauri-app",
  "version": "0.6.0",
  "private": true,
  "description": "BytePilot desktop application powered by Tauri",
  "scripts": {
    "dev": "set PATH=%USERPROFILE%\\.cargo\\bin;%PATH% && tauri dev",
    "build": "set PATH=%USERPROFILE%\\.cargo\\bin;%PATH% && tauri build",
    "dev:tauri": "set PATH=%USERPROFILE%\\.cargo\\bin;%PATH% && tauri dev",
    "build:sidecar": "node esbuild.sidecar.mjs",
    "tauri": "set PATH=%USERPROFILE%\\.cargo\\bin;%PATH% && tauri",
    "prebuild": "npm run build:webview --prefix ../..",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: ok'",
    "clean": "set PATH=%USERPROFILE%\\.cargo\\bin;%PATH% && cargo clean"
  },
  "dependencies": {
    "@bytepilot/core": "0.6.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-store": "^2.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "typescript": "^5.5.0",
    "esbuild": "^0.24.0"
  }
}
